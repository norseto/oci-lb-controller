// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/debian
{
  "name": "go",
  "image": "mcr.microsoft.com/devcontainers/base:noble",
  "runArgs": [
    "--add-host=host.docker.internal:host-gateway",
    "--security-opt=seccomp=unconfined",
    "--security-opt=label=disable",
    "--cap-drop=ALL",
    "--cap-add=CHOWN",
    "--cap-add=FOWNER",
    "--cap-add=FSETID",
    "--cap-add=DAC_OVERRIDE",
    "--cap-add=AUDIT_WRITE",
    "--cap-add=KILL",
    "--cap-add=NET_BIND_SERVICE",
    "--cap-add=NET_RAW",
    "--cap-add=SETFCAP",
    "--cap-add=SETPCAP",
    "--cap-add=SETUID",
    "--cap-add=SETGID",
    "--cap-add=SYS_CHROOT",
    "--pids-limit=512",
    "--init"
  ],
  "features": {
    "ghcr.io/devcontainers/features/go:1": {
      "version": "1.25.9"
    },
    "ghcr.io/devcontainers/features/kubectl-helm-minikube:1": {
      "version": "latest",
      "helm": "latest",
      "minikube": "none"
    },
    "ghcr.io/mpriscella/features/sops:1": {},
    "ghcr.io/mpriscella/features/kind:1": {},
    "ghcr.io/rio/features/kustomize:1": {},
    "ghcr.io/audacioustux/devcontainers/kubebuilder:1": {},
    "ghcr.io/devcontainers/features/github-cli:1": {},
    // "ghcr.io/devcontainers/features/docker-outside-of-docker:1": { "moby": false }
  },

  // Use 'forwardPorts' to make a list of ports inside the container available locally.
  // "forwardPorts": [],

  // Configure tool-specific properties.
  "remoteEnv": {
    "CONTAINER_WORKSPACE_FOLDER": "${containerWorkspaceFolder}",
    "LOCAL_WORKSPACE_FOLDER": "${localWorkspaceFolder}",
  },
  "containerEnv": {
    "CURSOR_API_KEY": "${localEnv:CURSOR_API_KEY}",
    "CONTEXT7_API_KEY": "${localEnv:CONTEXT7_API_KEY}",
    "MISE_GITHUB_TOKEN": "${localEnv:MISE_GITHUB_TOKEN}",
    "MISE_LOG_LEVEL": "error",
    "GOCACHE": "/tmp/.gocache",
    "GOMODCACHE": "/tmp/.gomodcache",
    "GOPATH": "/go",
    "GOROOT": "/usr/local/go"
  },
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.shell.linux": "/bin/bash",
        "ninetyfive.indexingEnabled": "on",
        "go.gopath": "/go",
        "go.goroot": "/usr/local/go"
      },
      "extensions": []
    }
  },

  // Uncomment to connect as root instead. More info: https://aka.ms/dev-containers-non-root.
  "remoteUser": "vscode",
  "postCreateCommand": ".devcontainer/post-create.sh",

  "mounts": [
    "type=volume,source=vscode-aws-cred,target=/home/vscode/.aws,consistency=delegated",
    "type=volume,source=vscode-k8s-cred,target=/home/vscode/.kube,consistency=delegated",
    "type=volume,source=vscode-go-path-pkg,target=/go/pkg,consistency=delegated",
    "type=volume,source=vscode-go-cache,target=/tmp/.gocache,consistency=delegated",
    "type=volume,source=vscode-go-modcache,target=/tmp/.gomodcache,consistency=delegated",
    "type=volume,source=vscode-jetbrains,target=/home/vscode/.cache/JetBrains,consistency=delegated",
    "type=volume,source=codex-volume,target=/home/vscode/.codex,consistency=cached",
    "type=volume,source=cursor-volume,target=/home/vscode/.cursor,consistency=cached",
  ]
}
